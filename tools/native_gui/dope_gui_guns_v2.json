    "_comments": {
      "purpose": "Gun presets consumed by the GUI; extra fields are ignored by loader.",
      "fields": {
        "name": "Display label for the preset.",
        "caliber_inches": "Bore diameter in inches; keep to 3 decimals (UI uses %.3f).",
        "barrel_length_in": "Overall barrel length in inches; keep to 1 decimal (UI uses %.1f).",
        "muzzle_diameter_in": "Outside diameter at muzzle in inches; keep to 3 decimals (UI uses %.3f).",
        "barrel_material": "Enum key: cmv | 416ss | carbon (see kBarrelMaterialPresets).",
        "twist_rate_inches": "Twist in inches/turn; keep to 2 decimals (UI uses %.2f).",
        "zero_range_m": "Zero distance in meters; keep to 2 decimals (UI uses %.2f).",
        "sight_height_mm": "Sight height over bore in mm; keep to 2 decimals.",
        "free_floated": "Boolean; true if barrel is free-floated.",
        "suppressor_attached": "Boolean toggle.",
        "barrel_tuner_attached": "Boolean toggle.",
        "cold_bore_velocity_bias": "First-shot MV jump in fps; up to 2 decimals.",
        "angular_sigma_moa": "Rifle's physical cone in MOA; default 0.4 unless specified.",
        "chamber_time": "Time in seconds for chamber heating model (float). Leave null if unknown.",
        "barrel_profile": "Object with 'wall_thickness_mm' (float) and 'taper' (float). Leave values null.",
        "ammo_temp": "Default ammunition temperature in degrees Celsius (float). Leave null."
      },
